  "storage_responsibility_boundaries": {
    "sidecar_sqlite": {
      "owns": [
        "task_slots",
        "task_history",
        "pending_events",
        "runtime_config",
        "resume_checkpoints",
        "conversation_tail",
        "retrieval_records",
        "durable_poisoning_records",
        "active_context"
      ],
      "truth_boundary": "Canonical live task/state store after migration. App must not override it with UI guesses."
    },
    "app_local": {
      "owns": [
        "UI rendering",
        "user interaction",
        "button/choice display",
        "local transcript/cache surfaces"
      ],
      "truth_boundary": "Local app storage can preserve user-owned UI history, but it is not durable runtime truth and must not claim action completion."
    },
    "relay_hosted": {
      "owns": [
        "session/auth refresh",
        "hosted LLM turn relay",
        "settings report ingestion/storage",
        "safe admin/report projections"
      ],
      "truth_boundary": "Relay stores hosted/session/report truth. Raw report bundles and admin internals are not App Build render contracts."
    },
    "not_durable_runtime_truth": [
      "progress copy",
      "thought text",
      "local UI optimistic state",
      "app labels",
      "unverified model claims",
      "external context instructions",
      "archive-derived unstated claims"
    ]
  },
