# ─── Server ───────────────────────────────────────────────────────────────────
RELAY_HTTP_ADDR=:8080
RELAY_PUBLIC_BASE_URL=https://xmiloatyourside.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Required at startup. Postgres 14+ recommended.
RELAY_POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/xmilo?sslmode=disable

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
RELAY_JWT_SECRET=replace_me
RELAY_HANDOFF_SECRET=replace_me
RELAY_HANDOFF_AUDIENCE=xmilo-sol-site
RELAY_HANDOFF_MAX_AGE_SECONDS=300

# ─── AI provider (xAI / Grok) ─────────────────────────────────────────────────
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

# ─── Development shortcuts ────────────────────────────────────────────────────
# Set true to skip entitlement checks in local dev. MUST be false in production.
RELAY_DEV_ENTITLED=false

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# If SMTP_HOST is empty, verification links are printed to stdout (dev mode).
SMTP_FROM=noreply@xmiloatyourside.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ─── Admin ────────────────────────────────────────────────────────────────────
# Sent as X-Admin-Password header to /admin/* API endpoints.
# Generate with: openssl rand -hex 16
RELAY_ADMIN_PASSWORD=replace_me

# ─── Access rules (product locks — change only with product decision) ──────────
# code_only = launch mode, verified email + access code required
# public    = later public mode, trial/subscription/code surfaces can appear again
XMILO_ACCESS_MODE=code_only
XMILO_TRIAL_HOURS=12
XMILO_INVITE_BETA_DAYS=30

# ─── Billing ─────────────────────────────────────────────────────────────────
# RevenueCat REST API key (for server-side validation, future use)
REVENUECAT_API_KEY=
# Shared secret from RevenueCat dashboard → Webhooks → Auth header value
REVENUECAT_WEBHOOK_AUTH=
