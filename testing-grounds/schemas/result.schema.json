{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "xMilo Testing Grounds Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "fixture_id",
    "status",
    "zero_token",
    "cache_hit",
    "cache_status",
    "prompt_hash",
    "model_id",
    "runner_version",
    "runner_identity",
    "schema_hashes",
    "proof_level",
    "live_model_used",
    "production_endpoint_used",
    "phone_proof_used",
    "closure_allowed",
    "started_at",
    "completed_at",
    "evidence",
    "hard_fail_tags",
    "smallest_fail_seam",
    "recommended_owner_lane",
    "notes"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "fixture_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "REQUIRES_REVIEW", "SKIPPED"] },
    "zero_token": { "type": "boolean" },
    "cache_hit": { "type": "boolean" },
    "cache_status": { "type": "string", "enum": ["hit", "miss"] },
    "prompt_hash": { "type": "string" },
    "model_id": { "type": "string" },
    "runner_version": { "type": "string" },
    "runner_identity": { "type": "object" },
    "schema_hashes": { "type": "object" },
    "proof_level": { "type": "string", "enum": ["schema_only"] },
    "live_model_used": { "type": "boolean" },
    "production_endpoint_used": { "type": "boolean" },
    "phone_proof_used": { "type": "boolean" },
    "closure_allowed": { "type": "boolean" },
    "started_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "evidence": { "type": "object" },
    "hard_fail_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "smallest_fail_seam": { "type": "string" },
    "recommended_owner_lane": { "type": "string" },
    "notes": { "type": "string" }
  }
}
